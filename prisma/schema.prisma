generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "sqlite"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model User {
  id           Int            @id @default(autoincrement())
  uuid         String         @unique @default(cuid())
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  createdBy    String?        @map("created_by")
  updatedBy    String?        @map("updated_by")
  name         String
  email        String         @unique
  passwordHash String         @map("password_hash")
  subscriptions Subscription[]

  @@map("users")
}

model Product {
  id            Int               @id @default(autoincrement())
  uuid          String            @unique @default(cuid())
  createdAt     DateTime          @default(now()) @map("created_at")
  updatedAt     DateTime          @updatedAt @map("updated_at")
  createdBy     String?           @map("created_by")
  updatedBy     String?           @map("updated_by")
  level         Int               @default(0)
  name          String
  price         String
  platforms     ProductPlatform[]
  subscriptions Subscription[]

  @@map("products")
}

model ProductPlatform {
  id                Int      @id @default(autoincrement())
  uuid              String   @unique @default(cuid())
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  createdBy         String?  @map("created_by")
  updatedBy         String?  @map("updated_by")
  productUuid       String   @map("product_uuid")
  platform          String
  platformProductId String   @map("platform_product_id")
  platformPriceId   String   @map("platform_price_id")
  product           Product  @relation(fields: [productUuid], references: [uuid], onDelete: Cascade)

  @@unique([productUuid, platform])
  @@unique([platform, platformProductId])
  @@unique([platform, platformPriceId])
  @@map("product_platforms")
}

model Subscription {
  id                 Int                   @id @default(autoincrement())
  uuid               String                @unique @default(cuid())
  createdAt          DateTime              @default(now()) @map("created_at")
  updatedAt          DateTime              @updatedAt @map("updated_at")
  createdBy          String?               @map("created_by")
  updatedBy          String?               @map("updated_by")
  status             String
  productUuid        String                @map("product_uuid")
  userUuid           String                @map("user_uuid")
  currentPeriodStart DateTime?             @map("current_period_start")
  currentPeriodEnd   DateTime?             @map("current_period_end")
  canceledAt         DateTime?             @map("canceled_at")
  cancelAtPeriodEnd  Boolean               @default(false) @map("cancel_at_period_end")
  latestPaymentAt    DateTime?             @map("latest_payment_at")
  product            Product               @relation(fields: [productUuid], references: [uuid])
  user               User                  @relation(fields: [userUuid], references: [uuid])
  platform           SubscriptionPlatform?

  @@index([userUuid])
  @@index([productUuid])
  @@index([status])
  @@map("subscriptions")
}

model SubscriptionPlatform {
  id                     Int          @id @default(autoincrement())
  uuid                   String       @unique @default(cuid())
  createdAt              DateTime     @default(now()) @map("created_at")
  updatedAt              DateTime     @updatedAt @map("updated_at")
  createdBy              String?      @map("created_by")
  updatedBy              String?      @map("updated_by")
  subscriptionUuid       String       @unique @map("subscription_uuid")
  platform               String
  platformCustomerId     String       @map("platform_customer_id")
  platformSubscriptionId String       @map("platform_subscription_id")
  subscription           Subscription @relation(fields: [subscriptionUuid], references: [uuid], onDelete: Cascade)

  @@index([platform, platformCustomerId])
  @@unique([platform, platformSubscriptionId])
  @@map("subscription_platforms")
}

model SubscriptionLog {
  id                        Int      @id @default(autoincrement())
  uuid                      String   @unique @default(cuid())
  createdAt                 DateTime @default(now()) @map("created_at")
  updatedAt                 DateTime @updatedAt @map("updated_at")
  createdBy                 String?  @map("created_by")
  updatedBy                 String?  @map("updated_by")
  subscriptionUuid          String   @map("subscription_uuid")
  userUuid                  String   @map("user_uuid")
  action                    String
  status                    String
  platform                  String
  result                    Json

  @@index([subscriptionUuid])
  @@index([userUuid])
  @@index([action, status, platform])
  @@map("subscription_logs")
}

model WebhookEvent {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(cuid())
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  createdBy     String?  @map("created_by")
  updatedBy     String?  @map("updated_by")
  source        String
  eventId       String   @map("event_id")
  eventType     String   @map("event_type")
  receiveStatus String   @map("receive_status")
  receivedAt    DateTime @map("received_at")
  signature     String
  headersJson   String   @map("headers_json")
  payloadJson   String   @map("payload_json")

  @@unique([source, eventId])
  @@map("webhook_events")
}
